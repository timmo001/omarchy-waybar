{
  "include": ["~/.config/waybar/config.jsonc"],
  "position": "top",
  "custom/temperature": {
    "exec": "bash ~/.config/waybar/scripts/temperature.sh sensor.meter_d828_temperature 'Meter D828 Temperature'",
    "return-type": "json",
    "format": " {} °C",
    "tooltip": true,
    "restart-interval": 5,
    "on-click": "omarchy-launch-webapp 'http://homeassistant.local:8123/lovelace/office?more-info-entity-id=sensor.meter_d828_temperature'"
  }
}
